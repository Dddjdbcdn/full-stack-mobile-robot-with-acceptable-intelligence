<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <ros2_control name="Stm32HardwareInterface" type="system">
  <hardware>
    <plugin>topic_based_ros2_control/TopicBasedSystem</plugin>
    <param name="joint_commands_topic">/stm32/wheel_commands</param>
    <param name="joint_states_topic">/stm32/wheel_states</param>
    <param name="trigger_joint_command_threshold">0.000001</param>
    <param name="joint_commands_qos">BEST_EFFORT</param>
    <param name="joint_states_qos">BEST_EFFORT</param>
  </hardware>

  <joint name="left_wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="right_wheel_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>

</robot>